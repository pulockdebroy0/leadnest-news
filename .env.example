# ============================================================================
# Leadnest News — environment variables (Supabase edition)
# Copy to .env for local dev. For Vercel, add the same keys under
# Project → Settings → Environment Variables before your first deploy —
# the build pipeline runs migrations and seeding automatically (see
# package.json's "build" script), so nothing else is required afterward.
# ============================================================================

# ---- Database (REQUIRED) — Supabase Postgres --------------------------------
# In Supabase: Project Settings → Database → Connection string.
# DATABASE_URL: the POOLED connection (port 6543, via PgBouncer) — used for
#   all normal runtime queries. Append ?pgbouncer=true.
# DIRECT_URL: the DIRECT connection (port 5432, no pooler) — used only for
#   running migrations, which PgBouncer's transaction mode can't handle.
DATABASE_URL="postgresql://postgres:your-password@db.your-project-ref.supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres"

# ---- Supabase (REQUIRED) — also used for Storage (bucket: news-media) ------
# Project Settings → API in the Supabase dashboard.
SUPABASE_URL="https://your-project-ref.supabase.co"
# Public/anon key — not currently read by any server code in this project
# (all storage operations run server-side with the service role key below),
# kept here for completeness / future client-side Supabase use.
SUPABASE_ANON_KEY="your-anon-key"
# Service role key — SECRET, server-only. Used by src/lib/supabase.ts to
# upload/delete/replace files in the "news-media" bucket, bypassing RLS.
# Never expose this to the browser or prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ---- Auth.js (REQUIRED) -----------------------------------------------------
# Generate with: openssl rand -hex 32
AUTH_SECRET="change-me-to-a-long-random-string"
# Optional: src/lib/auth.ts sets trustHost: true, so Auth.js infers the
# canonical URL from the request's Host header on Vercel — only set this if
# you hit callback-URL issues.
AUTH_URL="https://leadnest.tech"

# ---- First-run admin account (REQUIRED) -------------------------------------
# Created automatically during the Vercel build (prisma/seed.ts runs as part
# of `npm run build`). Change the password immediately after first login.
ADMIN_EMAIL="admin@leadnest.tech"
ADMIN_PASSWORD="change-me-immediately"

# ---- AI CMS tools --------------------------------------------------------
# Default provider: Groq (free tier). Automatic fallback to OpenRouter, then
# Hugging Face, if Groq is unavailable or fails. None of the three are
# required for the app to build or run — only for the AI buttons in the
# article editor to produce output.
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

OPENROUTER_API_KEY=""
OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct:free"

HUGGINGFACE_API_KEY=""
HUGGINGFACE_MODEL="meta-llama/Llama-3.2-3B-Instruct"

# Tuning (optional) — sensible defaults are built in.
AI_TIMEOUT_MS="20000"
AI_RPM_GROQ="25"
AI_RPM_OPENROUTER="15"
AI_RPM_HUGGINGFACE="10"
# Google Gemini's adapter still exists (src/lib/ai/gemini.ts) if you want to
# re-enable it later, but it's not part of the default chain — see README.
# GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-2.0-flash"
# AI_RPM_GEMINI="12"

# ---- Analytics, Search Console & Ads (optional) -----------------------------
# Also editable at runtime from the admin Settings page — an env var here
# always wins over a value saved in the database.
GA4_MEASUREMENT_ID=""
GSC_VERIFICATION=""
CLARITY_PROJECT_ID=""
ADSENSE_CLIENT_ID=""
AD_MANAGER_NETWORK_CODE=""

# ---- Web push notifications (optional) -------------------------------------
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# ---- Outbound email (optional) ---------------------------------------------
# Checked for "is email configured" status; sendEmail() itself still needs a
# provider implementation in src/lib/mailer.ts. Set only ONE of these three.
RESEND_API_KEY=""
SENDGRID_API_KEY=""
SMTP_URL=""

# ---- Local database seeding (optional, dev/staging only) -------------------
# When "true", the seed step also inserts sample articles/authors. Leave
# unset ("false") in production so the database ships with real content only.
SEED_SAMPLE_DATA="false"
